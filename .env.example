# ===========================================================================
# Silica Agent — Configuration
# Copy this file to .env and fill in your values.
# ===========================================================================

# ---------------------------------------------------------------------------
# 1. CORE LLM CONFIGURATION (Fundamental)
# ---------------------------------------------------------------------------

# Main LLM Model (litellm format)
# Examples: openrouter/anthropic/claude-sonnet-4-20250514, openai/gpt-4o,
#           ollama/llama3.1:8b (local Ollama at http://localhost:11434)
# SILICA_MODEL=openrouter/google/gemini-3.5-flash

# LLM Provider preset (derived from SILICA_MODEL by default)
# Examples: openrouter, lmstudio, ollama
# NOTE: Silica is tool-driven — with ollama pick a model that supports
# function-calling (e.g. llama3.1, qwen2.5); text-only models will stall.
# SILICA_PROVIDER=openrouter

# API keys — set OPENROUTER_API_KEY for the openrouter preset; ANTHROPIC_API_KEY /
# OPENAI_API_KEY are only needed if SILICA_MODEL targets that provider directly
# (bypassing SILICA_PROVIDER), since litellm reads them itself.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Maximum tokens for LLM generation (fallback for missing max_tokens). Default: 256000
# MAX_TOKENS=256000


# ---------------------------------------------------------------------------
# 2. VAULT & BACKEND SETTINGS (Fundamental)
# ---------------------------------------------------------------------------

# Obsidian vault path (required for the fs/headless backend)
# SILICA_VAULT=/path/to/your/vault

# Driver backend: fs (default, headless filesystem) or cli (live Obsidian desktop via CDP)
# SILICA_BACKEND=fs

# Obsidian CLI vault name (only required for cli backend multi-vault setups)
# SILICA_VAULT_NAME=My Vault

# Timeout in seconds for Obsidian desktop app CDP calls (cli backend only). Default: 8
# SILICA_OBSIDIAN_CLI_TIMEOUT=8

# Name of the inbox folder inside the vault, for staging inbound files. Default: Inbox
# SILICA_INBOX_DIR=Inbox

# Git commit safety net for vault writes: off (default) or auto (commit after each write batch)
# SILICA_GIT_COMMIT=off

# Domain-pack overlay name (overrides vault.yaml manifest if set)
# SILICA_DOMAIN=

# Override directory for domain recipe packs (defaults to silica/domains)
# SILICA_DOMAINS_DIR=


# ---------------------------------------------------------------------------
# 3. SUB-AGENT WORKER SETTINGS (Advanced)
# ---------------------------------------------------------------------------
# Used for concurrent background tasks (e.g. deduplication, refiner).
# If unset, worker tasks automatically fall back to the main model configuration.

# Worker LLM Model (litellm format)
# Examples: openrouter/google/gemma-2-9b-it, lmstudio/qwen/qwen3.5-9b
# SILICA_WORKER_MODEL=lmstudio/qwen/qwen3.5-9b

# Worker provider preset name
# Examples: openrouter, lmstudio
# SILICA_WORKER_PROVIDER=lmstudio

# Explicit worker API key override (overrides preset's API key)
# SILICA_WORKER_API_KEY=lm-studio

# Maximum concurrent sub-agent execution threads. Default: 3
# SILICA_SUBAGENT_MAX_CONCURRENT=3

# Global ceiling on concurrent worker-model LLM calls. Default: 4
# SILICA_WORKER_MAX_CONCURRENT=4


# ---------------------------------------------------------------------------
# 4. EMBEDDING MODEL SETTINGS (Advanced)
# ---------------------------------------------------------------------------
# Used by silica_embed_refresh and semantic deduplication search.

# Embedding model name
# Example: qwen3-embedding-4b (LM Studio), text-embedding-3-small (OpenAI)
# SILICA_EMBEDDING_MODEL=qwen3-embedding-4b

# Base URL for the embeddings endpoint (defaults to LM Studio local)
# SILICA_EMBEDDING_BASE_URL=http://localhost:1234/v1

# API key for the embeddings endpoint
# SILICA_EMBEDDING_API_KEY=lm-studio


# ---------------------------------------------------------------------------
# 5. SIMILARITY & DEDUP THRESHOLDS (Advanced)
# ---------------------------------------------------------------------------
# Tune how aggressively notes get merged, patched, or split as new concepts.

# Cosine similarity ≥ this → strong duplicate, patch the existing note. Default: 0.85
# SILICA_SIM_THRESHOLD_HIGH=0.85

# Cosine similarity ≤ this → clearly new concept, write a new note. Default: 0.65
# SILICA_SIM_THRESHOLD_LOW=0.65

# Title-only cosine similarity to promote a pair into the dedup borderline window. Default: 0.80
# SILICA_SIM_TITLE_THRESHOLD=0.80

# Minimum cosine similarity to the vault/doc theme for a concept to be kept. Default: 0.35
# SILICA_SIM_THRESHOLD_THEME=0.35

# Candidate notes retrieved per note during dedup scans. Default: 5
# SILICA_DEDUP_SCAN_K=5

# Language for the co-occurrence graph — auto detects, or set an explicit code. Default: auto
# SILICA_COOCCURRENCE_LANG=auto

# Mindmap (/map <nota>): radial map rooted on one note, written to maps/<stem>.canvas.
# Node cap (breathing room), latent neighbours asked of relatedness, wikilink BFS depth.
# SILICA_MINDMAP_MAX_NODES=35
# SILICA_MINDMAP_LATENT_K=10
# SILICA_MINDMAP_HOPS=2


# ---------------------------------------------------------------------------
# 6. WEB SEARCH & PDF NUCLEATION (Advanced)
# ---------------------------------------------------------------------------

# API key for Tavily search (enables the /web-search command).
# The bare name TAVILY_API_KEY is also accepted as a fallback if this is unset.
# SILICA_TAVILY_API_KEY=

# PDF-to-Markdown converter: mineru (default, silica[pdf] extra), docling, or opendataloader
# SILICA_PDF_PROVIDER=mineru


# ---------------------------------------------------------------------------
# 7. AGENT BEHAVIOR & UI SETTINGS (Advanced)
# ---------------------------------------------------------------------------

# Maximum context tokens before the agent triggers a warning (auto-detected if unset).
# Pins the window for LOCAL providers (LM Studio, Ollama) only; OpenRouter always
# uses the provider-reported context_length and ignores this pin.
# SILICA_MAX_CONTEXT=60000

# Tool progress display level: off, new, all, verbose
# SILICA_TOOL_PROGRESS=all

# Debug logging on stderr (True/False)
# SILICA_VERBOSE=False

# Show reasoning/thinking blocks from the model (True/False)
# SILICA_SHOW_THINKING=True

# Startup banner art (True → wordmark, False → plain one-liner)
# SILICA_SHOW_BANNER=True


# ---------------------------------------------------------------------------
# 8. TOKEN BUDGET OVERRIDES (Expert)
# ---------------------------------------------------------------------------
# Per-capability generation ceilings and distiller chunking knobs. All have safe
# defaults; override only to tune cost/latency.
# NOTE: these are read WITHOUT the SILICA_ prefix (bare names), unlike the above.

# Max generation tokens per capability. enrich/refine fall back to MAX_TOKENS (256000).
# DEDUP_MAX_TOKENS=1024
# ORPHAN_MAX_TOKENS=512
# EXPAND_MAX_TOKENS=4096
# ENRICH_MAX_TOKENS=256000
# REFINE_MAX_TOKENS=256000

# Distiller chunking / delegation budget.
# MODEL_CONTEXT_WINDOW=0             # 0 = auto-detect from the model
# DISTILLER_MAX_TOKENS=0            # 0 = no explicit ceiling (derive from context window)
# DISTILLER_TOKEN_SAFETY_MARGIN=2048
# DISTILLER_CHUNK_MAX_BYTES=30720   # 30 * 1024
