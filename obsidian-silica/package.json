{
  "name": "silica-bridge",
  "version": "0.0.1",
  "description": "Bridge the Silica knowledge-graph agent to an Obsidian vault over a local WebSocket.",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "node --test *.test.ts"
  },
  "keywords": ["obsidian-plugin", "silica"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.0"
  }
}
